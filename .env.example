# Copy this file to `.env` and fill in the values. Both are required by the generation scripts (they raise an error on startup if either is missing).

# API key for the OpenAI-compatible endpoint (also used to serve Gemini models).
# - OpenAI:     sk-...
# - OpenRouter: sk-or-v1-...   (OpenRouter is OpenAI-compatible; no code changes needed)
OPENAI_LLM_API_KEY=

# Base URL of the OpenAI-compatible endpoint.
# - OpenAI:     https://api.openai.com/v1
# - OpenRouter: https://openrouter.ai/api/v1
#
# When using OpenRouter, pass provider-namespaced model slugs (e.g. via preprocess_data.py's
# --classification-model / --compression-model), such as:
#   openai/gpt-4o, openai/gpt-4o-mini, openai/gpt-4.1, google/gemini-2.5-flash, google/gemini-3-pro-preview
OPENAI_BASE_URL=

# Llama Cloud API key, used by scripts/preprocess_data.py to parse non-.txt course files
# (PDF / PPT / PPTX / DOCX / MD) via LlamaParse. Only required when preprocessing such files;
# plain-text (.txt) inputs do not need it.
LLAMA_CLOUD_API_KEY=
